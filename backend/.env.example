# Copy to ".env" for local overrides (never commit ".env").

NODE_ENV=development
PORT=4000

# Number of trusted reverse proxies in front of Node (0 = off).
TRUST_PROXY=0

# Comma-separated browser origins, or "*" in development only.
CORS_ORIGIN=*

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
REQUEST_BODY_LIMIT=100kb
