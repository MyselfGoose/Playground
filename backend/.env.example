# Copy to ".env" for local overrides (never commit ".env").
#
# Quick start: you can run `npm run dev` without a .env file — development
# mode uses defaults in src/config/devDefaults.js (local Mongo + dev JWT keys).
# For production, you MUST set every secret and MONGO_URI explicitly.

NODE_ENV=development
PORT=4000

# Behind Railway / Render / Heroku, keep ≥1 so rate limits and req.ip see the real client (defaults to 1 in production if unset).
TRUST_PROXY=0
# Comma-separated browser origins (must match your Next.js URL exactly, no trailing slash). Never use * in production.
# Production example (Vercel):
# CORS_ORIGIN=https://playground-chi-neon.vercel.app
CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
REQUEST_BODY_LIMIT=100kb

# MongoDB (required). See src/docs/mongodb.md
MONGO_URI=mongodb://127.0.0.1:27017/games_platform

# JWT — use long random strings; in production each secret must be >= 32 chars and must differ.
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-ok!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-diff!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

BCRYPT_COST=12

# Stricter limits for POST /register and POST /login only
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# NPAT (Name Place Animal Thing) — WebSocket game under /npat namespace
NPAT_MAX_PLAYERS=8
NPAT_ROOM_CODE_LENGTH=4
NPAT_MIN_PLAYERS_TO_START=2
NPAT_SUBMIT_RATE_MS=400
NPAT_SWITCH_TEAM_RATE_MS=600
NPAT_ROUND_END_COUNTDOWN_MS=10000
NPAT_BETWEEN_ROUNDS_MS=5000
NPAT_STARTING_MS=1000

# NPAT AI scoring (Gemini). Optional in dev — without a key, rounds use offline letter/duplicate scoring.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# NPAT_EVAL_TIMEOUT_MS=25000
# NPAT_EVAL_MAX_RETRIES=2
# NPAT_EVAL_MAX_ANSWER_CHARS=120

# httpOnly cookies — Secure defaults to true in production
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.example.com

# Seeding (scripts/seed.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThis!Strong12

SEED_USER_USERNAME=testuser
SEED_USER_EMAIL=testuser@example.com
SEED_USER_PASSWORD=ChangeThis!Strong12

# db:reset only (never enable in production)
# ALLOW_DB_RESET=true
