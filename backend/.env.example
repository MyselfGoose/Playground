# Copy to ".env" for local overrides (never commit ".env").
#
# Quick start: you can run `npm run dev` without a .env file — development
# mode uses defaults in src/config/devDefaults.js (local Mongo + dev JWT keys).
# For production, you MUST set every secret and MONGO_URI explicitly.

NODE_ENV=development
PORT=4000

# Behind Railway / Render / Heroku, keep ≥1 so rate limits and req.ip see the real client (defaults to 1 in production if unset).
TRUST_PROXY=0
# Comma-separated browser origins (must match your Next.js URL exactly, no trailing slash). Never use * in production.
# Include every origin you use in the browser, e.g. `localhost` and `127.0.0.1` are different.
# Local dev (both):
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Production example (Vercel):
# CORS_ORIGIN=https://playground-chi-neon.vercel.app

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
REQUEST_BODY_LIMIT=100kb

# MongoDB (required). See src/docs/mongodb.md
MONGO_URI=mongodb://127.0.0.1:27017/games_platform

# JWT — use long random strings; in production each secret must be >= 32 chars and must differ.
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-ok!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-diff!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

BCRYPT_COST=12

# Stricter limits for POST /register and POST /login only
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# NPAT (Name Place Animal Thing) — WebSocket game under /npat namespace
NPAT_MAX_PLAYERS=8
NPAT_ROOM_CODE_LENGTH=4
NPAT_MIN_PLAYERS_TO_START=2
NPAT_SUBMIT_RATE_MS=400
NPAT_SWITCH_TEAM_RATE_MS=600
NPAT_ROUND_END_COUNTDOWN_MS=10000
NPAT_BETWEEN_ROUNDS_MS=5000
NPAT_STARTING_MS=1000

# NPAT AI scoring (Gemini). Optional in dev — without a key, rounds use offline letter/duplicate scoring.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Interactive mode is used for in-room end-of-game evaluation.
# Keep retries low to protect latency, rely on deterministic fallback when exhausted.
# NPAT_EVAL_INTERACTIVE_TIMEOUT_MS=15000
# NPAT_EVAL_INTERACTIVE_MAX_RETRIES=0
# NPAT_EVAL_INTERACTIVE_MAX_OUTPUT_TOKENS=3072
# Background mode is used for health probes and post-fallback upgrade attempts.
# NPAT_EVAL_TIMEOUT_MS=25000
# NPAT_EVAL_MAX_RETRIES=2
# NPAT_EVAL_MAX_ANSWER_CHARS=120
# NPAT_EVAL_MAX_OUTPUT_TOKENS=8192

# httpOnly cookies — Secure defaults to true in production.
# IMPORTANT: Cross-domain deployments (e.g. Vercel frontend → Railway backend) require:
#   COOKIE_SAME_SITE=none   (so cookies are sent cross-site)
#   COOKIE_SECURE=true      (required by browsers when SameSite=none)
# In production, COOKIE_SAME_SITE defaults to "none" when unset.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.example.com

# Seeding (scripts/seed.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThis!Strong12

SEED_USER_USERNAME=testuser
SEED_USER_EMAIL=testuser@example.com
SEED_USER_PASSWORD=ChangeThis!Strong12

# db:reset only (never enable in production)
# ALLOW_DB_RESET=true

# --- GitHub feedback (POST /api/v1/feedback) ---
# Fine-grained PAT: "Issues" read/write to open issues. Optional screenshots are stored in-repo via the Contents API,
# so also grant "Contents" read/write on the same repository (or omit screenshots / accept upload-fallback text in the issue).
# Never expose GITHUB_TOKEN to the browser or frontend env.
#
# One-time repo setup: create labels so typed issues can be tagged (API returns 422 if a label does not exist).
#   feedback, bug, enhancement, ui
# The server tries typed labels first, then only "feedback", then creates the issue with no labels (title still shows type).
#
# GITHUB_TOKEN=ghp_xxxxxxxx
# GITHUB_OWNER=your-org-or-user
# GITHUB_REPO=your-repo
#
# Kill switch (503 for all feedback posts):
# FEEDBACK_ENABLED=false
#
# FEEDBACK_RATE_LIMIT_WINDOW_MS=900000
# FEEDBACK_RATE_LIMIT_MAX=5
# FEEDBACK_BODY_LIMIT=8mb
# FEEDBACK_SCREENSHOT_MAX_BYTES=1048576
# FEEDBACK_SCREENSHOTS_PATH=.github/feedback-screenshots
