#!/usr/bin/env bash
# Games platform — one-command local development startup.
# Usage: ./startup [--no-install] [--no-seed] [--fresh] [--verbose|-v] [--quiet|-q]
#
# Requires: GNU Bash 4.3+ (for wait -n), Node.js, npm (or pnpm/yarn per lockfile).

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="${ROOT}/backend"
FRONTEND_DIR="${ROOT}/frontend"

NO_INSTALL=false
NO_SEED=false
FRESH=false
VERBOSE=false
QUIET=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-install) NO_INSTALL=true ;;
    --no-seed) NO_SEED=true ;;
    --fresh) FRESH=true ;;
    --verbose | -v) VERBOSE=true ;;
    --quiet | -q) QUIET=true ;;
    -h | --help)
      cat <<'HELP'
Games platform — local dev startup

Usage: ./startup [options]

Options:
  --no-install   Skip npm/pnpm/yarn install (fail if node_modules missing)
  --no-seed      Skip backend database seed
  --fresh        Run backend db:reset before seed (dev only; requires Mongo)
  -v, --verbose  Extra diagnostic output
  -q, --quiet    Minimal output (errors still print)

Requires: Bash 4.3+, Node.js (see backend/package.json engines), MongoDB for API.

Alternative: node scripts/dev.js [same flags]
HELP
      exit 0
      ;;
    *)
      echo "Unknown option: $1 (use --help)" >&2
      exit 1
      ;;
  esac
  shift
done

if [[ "$VERBOSE" == true && "$QUIET" == true ]]; then
  echo "Cannot use --verbose and --quiet together." >&2
  exit 1
fi

log_info() { [[ "$QUIET" == true ]] && return 0; printf '→ %s\n' "$*"; }
log_ok() { [[ "$QUIET" == true ]] && return 0; printf '✔ %s\n' "$*"; }
log_warn() { printf '⚠ %s\n' "$*" >&2; }
log_err() { printf '✖ %s\n' "$*" >&2; }
vlog() { [[ "$VERBOSE" == true ]] && printf '  [verbose] %s\n' "$*" >&2 || true; }

die() {
  log_err "$1"
  exit "${2:-1}"
}

require_dir() {
  [[ -d "$1" ]] || die "Missing directory: $1"
}

require_file() {
  [[ -f "$1" ]] || die "Missing file: $1"
}

read_env_kv() {
  local file="$1" key="$2"
  [[ -f "$file" ]] || return 1
  local line
  line="$(grep -E "^[[:space:]]*${key}=" "$file" 2>/dev/null | tail -1)" || return 1
  [[ -n "$line" ]] || return 1
  local val="${line#*=}"
  val="${val%%#*}"
  val="$(echo "$val" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")"
  echo "$val"
}

check_structure() {
  log_info "Checking project layout…"
  require_dir "$BACKEND_DIR"
  require_dir "$FRONTEND_DIR"
  require_file "${BACKEND_DIR}/package.json"
  require_file "${FRONTEND_DIR}/package.json"
  log_ok "Project layout OK (backend + frontend)"
}

detect_package_manager() {
  if [[ -f "${ROOT}/pnpm-lock.yaml" ]]; then echo pnpm
  elif [[ -f "${ROOT}/yarn.lock" ]]; then echo yarn
  elif [[ -f "${ROOT}/package-lock.json" ]] || [[ -f "${BACKEND_DIR}/package-lock.json" ]]; then echo npm
  else echo npm
  fi
}

PM="$(detect_package_manager)"
vlog "Detected package manager (repo): ${PM}"

# Per-package-dir we use lockfile next to package.json
pm_for_dir() {
  local dir="$1"
  if [[ -f "${dir}/pnpm-lock.yaml" ]]; then echo pnpm
  elif [[ -f "${dir}/yarn.lock" ]]; then echo yarn
  else echo npm
  fi
}

check_node() {
  log_info "Checking Node.js…"
  command -v node >/dev/null 2>&1 || die "Node.js is not installed. Install Node >= 20.10 (see backend/package.json engines)."
  local need
  need="$(node --input-type=module -e "
    import fs from 'fs';
    const p = JSON.parse(fs.readFileSync('${BACKEND_DIR}/package.json','utf8'));
    const e = p.engines?.node || '>=20.10.0';
    const m = e.replace(/\\s/g,'').match(/^>=(\\d+)\\.(\\d+)\\.(\\d+)/);
    if (m) process.stdout.write(m[1]+'.'+m[2]+'.'+m[3]);
    else process.stdout.write('20.10.0');
  ")"
  vlog "Minimum Node from engines: ${need}"
  node --input-type=module -e "
    const cur = process.version.slice(1).split('.').map(Number);
    const need = '${need}'.split('.').map(Number);
    const ok = cur[0] > need[0] || (cur[0]===need[0] && (cur[1] > need[1] || (cur[1]===need[1] && cur[2] >= need[2])));
    if (!ok) { console.error('Node', process.version, 'is below required', '${need}'); process.exit(1); }
  " || die "Node.js version is too old (need >= ${need})."
  log_ok "Node $(node -v) satisfies engines (>= ${need})"
}

check_core_tools() {
  log_info "Checking core tools…"
  case "$PM" in
    npm) command -v npm >/dev/null 2>&1 || die "npm is not installed (required)." ;;
    pnpm) command -v pnpm >/dev/null 2>&1 || die "pnpm is not installed. Install: corepack enable && corepack prepare pnpm@latest --activate" ;;
    yarn) command -v yarn >/dev/null 2>&1 || die "yarn is not installed. Install: npm i -g yarn" ;;
  esac
  log_ok "Package manager: ${PM}"
}

optional_mongod_hint() {
  local uri="${1:-}"
  if [[ "$uri" == *"127.0.0.1"* ]] || [[ "$uri" == *"localhost"* ]]; then
    if command -v mongosh >/dev/null 2>&1; then
      if ! mongosh "$uri" --eval "db.runCommand({ ping: 1 })" --quiet >/dev/null 2>&1; then
        log_warn "Could not ping MongoDB with mongosh (server may still be reachable)."
      fi
    elif command -v nc >/dev/null 2>&1; then
      if ! nc -z 127.0.0.1 27017 2>/dev/null; then
        log_warn "Nothing listening on 127.0.0.1:27017 — start MongoDB or update MONGO_URI in backend/.env"
      fi
    elif command -v timeout >/dev/null 2>&1 && timeout 1 bash -c 'echo > /dev/tcp/127.0.0.1/27017' 2>/dev/null; then
      :
    else
      vlog "Could not probe localhost:27017 (install nc or mongosh for better checks)."
    fi
  fi
}

setup_env_files() {
  log_info "Checking environment files…"
  if [[ ! -f "${BACKEND_DIR}/.env" ]]; then
    if [[ -f "${BACKEND_DIR}/.env.example" ]]; then
      cp "${BACKEND_DIR}/.env.example" "${BACKEND_DIR}/.env"
      log_ok "Created backend/.env from .env.example"
    else
      log_warn "backend/.env missing and no .env.example — backend dev defaults may apply at runtime."
    fi
  else
    log_ok "backend/.env exists"
  fi

  if [[ ! -f "${FRONTEND_DIR}/.env.local" ]]; then
    if [[ -f "${FRONTEND_DIR}/.env.example" ]]; then
      cp "${FRONTEND_DIR}/.env.example" "${FRONTEND_DIR}/.env.local"
      log_ok "Created frontend/.env.local from .env.example"
    else
      vlog "No frontend/.env.example — skipping .env.local"
    fi
  else
    log_ok "frontend/.env.local exists"
  fi
}

install_dir() {
  local dir="$1" label="$2"
  local pm
  pm="$(pm_for_dir "$dir")"
  vlog "${label}: using ${pm} in ${dir}"

  if [[ "$NO_INSTALL" == true ]]; then
    if [[ ! -d "${dir}/node_modules" ]]; then
      die "${label}: node_modules missing but --no-install was passed. Run without --no-install once."
    fi
    log_ok "${label}: skipping install (--no-install)"
    return 0
  fi

  local run_ci=false
  if [[ "$pm" == npm ]] && [[ -f "${dir}/package-lock.json" ]]; then
    run_ci=true
  fi

  pushd "$dir" >/dev/null
  local attempt=1
  while [[ "$attempt" -le 2 ]]; do
    vlog "${label}: install attempt ${attempt}"
    set +e
    if [[ "$run_ci" == true ]]; then
      npm ci
      rc=$?
    else
      case "$pm" in
        npm)
          npm install
          rc=$?
          ;;
        pnpm)
          if [[ -f pnpm-lock.yaml ]]; then
            pnpm install --frozen-lockfile
            rc=$?
            if [[ "$rc" -ne 0 ]]; then
              pnpm install
              rc=$?
            fi
          else
            pnpm install
            rc=$?
          fi
          ;;
        yarn)
          yarn install
          rc=$?
          ;;
      esac
    fi
    set -e
    if [[ "$rc" -eq 0 ]]; then
      log_ok "${label}: dependencies installed"
      popd >/dev/null
      return 0
    fi
    log_warn "${label}: install failed (exit ${rc}); cleaning node_modules and retrying once…"
    rm -rf node_modules
    run_ci=false
    attempt=$((attempt + 1))
  done
  popd >/dev/null
  die "${label}: dependency install failed after retry."
}

check_mongodb() {
  log_info "Checking MongoDB (MONGO_URI)…"
  pushd "$BACKEND_DIR" >/dev/null
  node scripts/checkMongo.js
  local uri
  uri="$(read_env_kv .env MONGO_URI 2>/dev/null || true)"
  if [[ -z "$uri" ]]; then
    uri="mongodb://127.0.0.1:27017/games_platform"
  fi
  popd >/dev/null
  optional_mongod_hint "$uri"
  log_ok "MongoDB reachable"
}

run_fresh_reset() {
  [[ "$FRESH" == true ]] || return 0
  log_info "Running database reset (--fresh)…"
  pushd "$BACKEND_DIR" >/dev/null
  ALLOW_DB_RESET=true NODE_ENV=development npm run db:reset
  popd >/dev/null
  log_ok "Database reset complete"
}

run_seed() {
  [[ "$NO_SEED" == true ]] && {
    log_ok "Skipping seed (--no-seed)"
    return 0
  }
  [[ -f "${BACKEND_DIR}/scripts/seed.js" ]] || {
    vlog "No scripts/seed.js — skip seed"
    return 0
  }
  log_info "Running database seed (idempotent upserts)…"
  pushd "$BACKEND_DIR" >/dev/null
  npm run db:seed
  popd >/dev/null
  log_ok "Seed step finished"
}

read_backend_port() {
  local p
  p="$(read_env_kv "${BACKEND_DIR}/.env" PORT 2>/dev/null || true)"
  if [[ -z "$p" ]]; then p=4000; fi
  echo "$p"
}

read_frontend_port() {
  local p
  p="$(read_env_kv "${FRONTEND_DIR}/.env.local" PORT 2>/dev/null || true)"
  if [[ -z "$p" ]]; then p=3000; fi
  echo "$p"
}

port_pids() {
  local port="$1"
  if command -v fuser >/dev/null 2>&1; then
    fuser -n tcp "$port" 2>/dev/null | tr ' ' '\n' | grep -E '^[0-9]+$' || true
    return 0
  fi
  if command -v lsof >/dev/null 2>&1; then
    lsof -ti tcp:"$port" 2>/dev/null || true
    return 0
  fi
  if command -v ss >/dev/null 2>&1; then
    ss -ltnp "sport = :$port" 2>/dev/null | sed -n 's/.*pid=\([0-9]*\).*/\1/p' | sort -u || true
    return 0
  fi
  return 1
}

free_port() {
  local port="$1" name="$2"
  local pids
  pids="$(port_pids "$port" | sort -u | tr '\n' ' ')"
  if [[ -z "${pids// }" ]]; then
    vlog "${name} port ${port} is free"
    return 0
  fi
  log_warn "${name}: port ${port} in use — stopping: ${pids}"
  for pid in $pids; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    if kill -TERM "$pid" 2>/dev/null; then
      sleep 0.3
      if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
      fi
    fi
  done
  log_ok "${name}: port ${port} cleared"
}

BACKEND_PID=""
FRONTEND_PID=""
CLEANED=false

cleanup() {
  [[ "$CLEANED" == true ]] && return 0
  CLEANED=true
  echo "" >&2
  log_info "Shutting down (cleanup)…"
  if [[ -n "${BACKEND_PID:-}" ]] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill -TERM "$BACKEND_PID" 2>/dev/null || true
  fi
  if [[ -n "${FRONTEND_PID:-}" ]] && kill -0 "$FRONTEND_PID" 2>/dev/null; then
    kill -TERM "$FRONTEND_PID" 2>/dev/null || true
  fi
  sleep 0.5
  if [[ -n "${BACKEND_PID:-}" ]] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill -KILL "$BACKEND_PID" 2>/dev/null || true
  fi
  if [[ -n "${FRONTEND_PID:-}" ]] && kill -0 "$FRONTEND_PID" 2>/dev/null; then
    kill -KILL "$FRONTEND_PID" 2>/dev/null || true
  fi
  wait "${BACKEND_PID:-}" 2>/dev/null || true
  wait "${FRONTEND_PID:-}" 2>/dev/null || true
  log_ok "Stopped."
}

start_servers() {
  local backend_port frontend_port
  backend_port="$(read_backend_port)"
  frontend_port="$(read_frontend_port)"

  free_port "$backend_port" "Backend"
  free_port "$frontend_port" "Frontend"

  trap cleanup INT TERM

  log_info "Starting backend (npm run dev) on port ${backend_port}…"
  (
    cd "$BACKEND_DIR"
    exec npm run dev
  ) 2>&1 | awk -v p="[backend]" '{ print p, $0; fflush(); }' &
  BACKEND_PID=$!

  log_info "Starting frontend (npm run dev) on port ${frontend_port}…"
  (
    cd "$FRONTEND_DIR"
    exec npm run dev -- -p "$frontend_port"
  ) 2>&1 | awk -v p="[frontend]" '{ print p, $0; fflush(); }' &
  FRONTEND_PID=$!

  echo "" >&2
  log_ok "Application is ready"
  echo "" >&2
  printf '   Backend:  http://localhost:%s\n' "$backend_port" >&2
  printf '   Frontend: http://localhost:%s\n' "$frontend_port" >&2
  echo "" >&2
  log_info "Press Ctrl+C to stop both servers."
  echo "" >&2

  set +e
  wait -n "$BACKEND_PID" "$FRONTEND_PID"
  ec=$?
  set -e
  cleanup
  exit "$ec"
}

main() {
  check_structure
  check_node
  check_core_tools
  setup_env_files
  install_dir "$BACKEND_DIR" "Backend"
  install_dir "$FRONTEND_DIR" "Frontend"
  check_mongodb
  run_fresh_reset
  run_seed
  start_servers
}

main
